<% content_for :title, "Users — Admin" %>
<% content_for :header_title, "Admin" %>

<%= render "admin/nav" %>

<div class="admin-header">
  <h2 class="admin-header__title">Users</h2>
</div>

<% if @users.any? %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.display_name %></td>
          <td><%= user.email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty-state"><p>No users yet.</p></div>
<% end %>
