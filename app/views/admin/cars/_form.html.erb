<% if car.errors.any? %>
  <div class="form-errors">
    <ul>
      <% car.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="form-group">
  <%= f.label :name, "Name" %>
  <%= f.text_field :name, placeholder: "e.g. Toyota Corolla" %>
</div>

<div class="form-group">
  <%= f.label :cost_per_km, "Cost per km (R)" %>
  <%= f.number_field :cost_per_km, step: "0.01", placeholder: "e.g. 4.50" %>
</div>

<div class="form-actions">
  <%= f.submit "Save", class: "btn btn--primary" %>
  <%= link_to "Cancel", admin_cars_path, class: "btn btn--ghost" %>
</div>
