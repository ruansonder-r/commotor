<% if membership.errors.any? %>
  <div class="form-errors">
    <ul>
      <% membership.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="form-group">
  <%= f.label :user_id, "User" %>
  <%= f.collection_select :user_id, @users, :id, :display_name, { prompt: "Select a user" } %>
</div>

<div class="form-group">
  <%= f.label :carpool_group_id, "Group" %>
  <%= f.collection_select :carpool_group_id, @carpool_groups, :id, :name, { prompt: "Select a group" } %>
</div>

<div class="form-group">
  <%= f.label :cost_split_percentage, "Cost split (0.0–1.0, e.g. 0.5 = 50%)" %>
  <%= f.number_field :cost_split_percentage, step: "0.01", min: "0.01", max: "1.0", placeholder: "0.5" %>
</div>

<div class="form-actions">
  <%= f.submit "Save", class: "btn btn--primary" %>
  <%= link_to "Cancel", admin_memberships_path, class: "btn btn--ghost" %>
</div>
